# ─── Anthropic ───────────────────────────────────────────
# LEAVE EMPTY if you are using a Claude Max subscription (the default).
# Auth comes from `claude` CLI login stored in ~/.claude/. See README Quick Start.
# Only set this if you want to bill the Anthropic API pay-as-you-go instead.
ANTHROPIC_API_KEY=

# ─── OpenAI (message triage + question answering) ───────
# Used by the Telegram bot to classify messages as questions vs coding tasks,
# and to answer questions directly. Leave empty to disable triage (all messages
# become coding tasks).
OPENAI_API_KEY=

# ─── Telegram ────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_ALLOWED_USER_ID=123456789

# ─── Redis ───────────────────────────────────────────────
# Use "redis" when running via docker compose, "localhost" for conda/local.
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=change_me

# ─── Git (target repository) ────────────────────────────
# The repo the agents will develop against. Can be any project.
# Docker: /workspace/project. Conda/local: absolute host path.
GIT_REPO_PATH=./workspace/project
GIT_REMOTE_URL=git@github.com:your-org/your-project.git
GIT_DEFAULT_BRANCH=main
GIT_USER_NAME=Claude Agent
GIT_USER_EMAIL=claude-agent@localhost

# ─── Web App (target project's dev server) ───────────────
# URL where the dev instance is accessible for UI testing.
# Docker: http://web-app:3000. Conda/local: http://localhost:3000.
WEB_APP_URL=http://localhost:3000
# Command to start the dev server (leave empty if already running).
WEB_APP_START_COMMAND=
WEB_APP_HEALTHCHECK_PATH=/
# Direct URL for screenshots (bypasses proxy/OAuth layers).
DEV_DIRECT_URL=http://localhost:3000

# ─── Deploy ─────────────────────────────────────────────
# Command to deploy the target project to production.
# Called after human approval on Telegram. Leave empty to skip deploy.
DEPLOY_PROD_COMMAND=

# ─── OAuth Test Accounts ─────────────────────────────────
# Only needed if the target app uses OAuth and QA needs to log in.
TEST_GOOGLE_EMAIL=
TEST_GOOGLE_PASSWORD=
TEST_GITHUB_USERNAME=
TEST_GITHUB_PASSWORD=

# ─── Basic Auth (if target dev site requires it) ─────────
BASIC_AUTH_USER=
BASIC_AUTH_PASSWORD=

# ─── App Mode ────────────────────────────────────────────
TESTING_MODE=true
APP_ENV=development

# ─── Agent Limits ────────────────────────────────────────
MAX_FEEDBACK_ITERATIONS=3
DEV_AGENT_TIMEOUT_SECONDS=1800
QA_AGENT_TIMEOUT_SECONDS=1200
UI_TEST_AGENT_TIMEOUT_SECONDS=1200
PLANNER_AGENT_TIMEOUT_SECONDS=600

# ─── Planner / Plan Coordinator ─────────────────────────
# In trust mode the coordinator auto-merges a sub-task when gate 2 passes
# AND the UI health score is at least this value. Below the threshold the
# task falls back to manual human review even in trust mode.
PLAN_AUTO_APPROVE_MIN_HEALTH=85

# ─── Triage Model ───────────────────────────────────────
# Model used for classifying Telegram messages as questions vs tasks.
TRIAGE_MODEL=gpt-4o-mini
# Model used for answering questions directly in Telegram.
CHAT_MODEL=gpt-4o-mini

# ─── Whisper ─────────────────────────────────────────────
# Local Whisper model size: tiny, base, small, medium, large-v3, turbo
WHISPER_MODEL=base

# ─── Dashboard ───────────────────────────────────────────
DASHBOARD_PORT=8095
